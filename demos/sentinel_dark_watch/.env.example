# Sentinel Dark Watch — environment configuration
# Copy to .env and fill in real values

# PostgreSQL (PostGIS)
POSTGRES_USER=stargraph
POSTGRES_PASSWORD=stargraph
POSTGRES_DB=sdw
POSTGRES_PORT=5441
POSTGRES_DSN=postgresql://stargraph:stargraph@localhost:5441/sdw

# Redis
REDIS_PORT=6391

# LLM (Ollama or compatible OpenAI-style endpoint)
LLM_PORT=41001
LLM_BASE_URL=http://localhost:41001/v1

# AIS Stream (https://aisstream.io)
AIS_STREAM_API_KEY=your-api-key-here
AIS_MODE=mock
