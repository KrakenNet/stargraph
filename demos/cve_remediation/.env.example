# SPDX-License-Identifier: Apache-2.0
#
# cve_remediation .env template. Copy to `.env` and fill values.
# `.env` is gitignored.

# ---------------------------------------------------------------------------
# LLM endpoint (DSPy nodes)
# ---------------------------------------------------------------------------
# Default points at the in-stack llm-shim (deterministic responder bound to
# :41001). Replace with your real OpenAI-compatible endpoint to drive a live
# LM (Ollama / vLLM / OpenAI / Anthropic-via-proxy / etc.).
LLM_BASE_URL=http://localhost:41001/v1
LLM_MODEL=gpt-oss:20b
LLM_API_KEY=placeholder
LLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# ServiceNow (CR creation in Phase 4)
# ---------------------------------------------------------------------------
# Demo default: in-stack mock-servicenow at :8089. Replace with a real
# instance + bearer token to exercise the live ServiceNow adapter.
SERVICENOW_BASE_URL=http://localhost:8089
SERVICENOW_INSTANCE=cve-rem-mock
SERVICENOW_AUTH_KIND=bearer       # one of: bearer | basic | mtls
SERVICENOW_BEARER_TOKEN=demo-token
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
SERVICENOW_MTLS_CERT_PATH=
SERVICENOW_MTLS_KEY_PATH=
SERVICENOW_TABLE_CHANGE_REQUEST=change_request

# ---------------------------------------------------------------------------
# Stores (DSNs/URLs the bootstrap.py script reads)
# ---------------------------------------------------------------------------
POSTGRES_USER=harbor
POSTGRES_PASSWORD=harbor
POSTGRES_DB=cve_rem
POSTGRES_PORT=5439
POSTGRES_DSN=postgresql://harbor:harbor@localhost:5439/cve_rem

PGVECTOR_USER=harbor
PGVECTOR_PASSWORD=harbor
PGVECTOR_DB=cve_rem_vec
PGVECTOR_PORT=5440
PGVECTOR_DSN=postgresql://harbor:harbor@localhost:5440/cve_rem_vec
PGVECTOR_DIM=384                  # all-MiniLM-L6-v2 default

REDIS_PORT=6390
REDIS_URL=redis://localhost:6390/0

RYUGRAPH_PORT=7687
RYUGRAPH_URL=bolt://localhost:7687
RYUGRAPH_USERNAME=
RYUGRAPH_PASSWORD=

# ---------------------------------------------------------------------------
# Harbor + Nautilus paths
# ---------------------------------------------------------------------------
HARBOR_CONFIG_DIR=./demos/cve_remediation
HARBOR_ARTIFACTS_ROOT=./.harbor/artifacts
HARBOR_CHECKPOINT_DB=./.harbor/cve-rem-checkpoint.sqlite
HARBOR_AUDIT_DSN=postgresql://harbor:harbor@localhost:5439/cve_rem

NAUTILUS_CONFIG_PATH=./demos/cve_remediation/nautilus.yaml
NAUTILUS_AUDIT_PATH=./.harbor/nautilus-audit.jsonl
NAUTILUS_SIGNING_KEY_PATH=./demos/cve_remediation/dev-keys/nautilus-broker.priv.pem

# ---------------------------------------------------------------------------
# Pack signing (krakntrust dev key)
# ---------------------------------------------------------------------------
KRAKNTRUST_TRUSTED_KEYS_DIR=./.harbor/trusted_keys
KRAKNTRUST_PUBKEY=./demos/cve_remediation/dev-keys/krakntrust-cve-rem.pub.pem

# ---------------------------------------------------------------------------
# Webhook secret (signed CVE-feed delivery)
# ---------------------------------------------------------------------------
CVE_REM_WEBHOOK_SECRET_CURRENT=replace-with-32+-bytes-of-randomness
CVE_REM_WEBHOOK_SECRET_PREVIOUS=
