{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stargraph.dev/schemas/manifest-v1.json",
  "additionalProperties": false,
  "description": "Plugin manifest (AC-9.5): identity + namespaces + provided entity kinds.\n\n``order`` (D1 design decision) controls plugin discovery/load priority,\nbounded ``[0, 10000]`` with default ``5000``. ``api_version`` is pinned\nto ``\"1\"`` -- bumps gate forward-compat upgrades explicitly (FR-6).",
  "properties": {
    "name": {
      "title": "Name",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    },
    "api_version": {
      "const": "1",
      "title": "Api Version",
      "type": "string"
    },
    "namespaces": {
      "items": {
        "type": "string"
      },
      "title": "Namespaces",
      "type": "array"
    },
    "provides": {
      "items": {
        "enum": [
          "tool",
          "skill",
          "store",
          "pack",
          "trigger",
          "mcp_adapter"
        ],
        "type": "string"
      },
      "title": "Provides",
      "type": "array"
    },
    "order": {
      "default": 5000,
      "maximum": 10000,
      "minimum": 0,
      "title": "Order",
      "type": "integer"
    }
  },
  "required": [
    "name",
    "version",
    "api_version",
    "namespaces",
    "provides"
  ],
  "title": "PluginManifest",
  "type": "object"
}
